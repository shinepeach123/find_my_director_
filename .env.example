# 数据库类型选择（sqlite, postgresql, excel）
# - sqlite: 本地测试/开发，零配置，适合小型项目
# - postgresql: 生产环境，企业级可靠性，适合大规模数据
# - excel: 简单使用场景，向后兼容
DB_TYPE=sqlite

# SQLite 数据库文件路径（仅在 DB_TYPE=sqlite 时需要）
# - 相对路径：相对于项目根目录
# - 绝对路径：直接使用
# - ":memory:": 内存数据库（测试用，重启后数据丢失）
SQLITE_DB_PATH=faculty.db

# PostgreSQL 数据库配置（仅在 DB_TYPE=postgresql 时需要）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://faculty_user:faculty_pass@localhost:5432/faculty_db

# DeepSeek API配置（可选，如果不在代码中硬编码）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# 调试模式
# DEBUG_MODE=false
